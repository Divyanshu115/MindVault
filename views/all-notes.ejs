<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Notes | MindVault</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

<div class="dashboard-layout">
    
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <h2><i class="fa-solid fa-brain gradient-text"></i> MindVault</h2>
        </div>
        
        <nav class="sidebar-nav">
            <a href="/dashboard" class="nav-item">
                <i class="fa-solid fa-pen-nib"></i> Editor
            </a>
            <a href="/all-notes" class="nav-item active">
                <i class="fa-solid fa-book-open"></i> All Notes
            </a>
            <a href="/deadlines" class="nav-item">
                <i class="fa-solid fa-clock"></i> Deadlines
            </a>
            <a href="/analytics" class="nav-item">
                <i class="fa-solid fa-chart-pie"></i> Analytics
            </a>
        </nav>
        
        <div class="sidebar-footer">
            <div class="user-profile">
                <div class="avatar"><%= user.charAt(0).toUpperCase() %></div>
                <div>
                    <div style="font-weight: 600; font-size: 14px;"><%= user %></div>
                    <div style="font-size: 12px; color: var(--text-secondary);">Pro Plan</div>
                </div>
            </div>
            <a href="/logout" title="Logout" style="color: var(--text-secondary);"><i class="fa-solid fa-arrow-right-from-bracket"></i></a>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="main-content">
        <div class="editor-header">
            <div style="color: var(--text-secondary); font-size: 14px;">
                <i class="fa-solid fa-book-open"></i> All Notes
            </div>
        </div>

        <div class="editor-body">
            <div class="notes-container" style="margin-top: 0;">
                <div class="notes-header">
                    <h3 style="font-size: 24px;">Your Knowledge Vault</h3>
                </div>
                
                <div class="notes-grid">
                    <% if(notes.length === 0){ %>
                        <div class="empty-state" style="grid-column: 1 / -1;">
                            <i class="fa-regular fa-folder-open"></i>
                            <p>No notes found. Create your first note in the Editor!</p>
                            <br>
                            <a href="/dashboard" class="btn btn-primary">Go to Editor</a>
                        </div>
                    <% } %>

                    <% notes.forEach(note => { %>
                        <div class="note-card" data-title="<%= note.title %>" data-content="<%= note.content %>" data-id="<%= note._id %>" onclick="openNoteFromAll(this)">
                            <h3><%= note.title %></h3>
                            <p><%= note.content %></p>
                            <div style="margin-top: 15px; font-size: 12px; color: var(--text-secondary); display: flex; justify-content: space-between;">
                                <span><i class="fa-regular fa-clock"></i> Saved</span>
                                <span style="color: var(--accent-purple);"><i class="fa-solid fa-wand-magic-sparkles"></i> AI Indexed</span>
                            </div>
                            <div style="margin-top:10px; display:flex; gap:8px; align-items:center;">
                                <form action="/delete-note" method="POST" style="margin:0;">
                                    <input type="hidden" name="title" value="<%= note.title %>">
                                    <button type="submit"
                                        style="background:red;color:white;border:none;padding:5px 10px;border-radius:5px;cursor:pointer;">
                                        Delete
                                    </button>
                                </form>
                                <button type="button" onclick="event.stopPropagation(); shareNote('<%= note._id %>')" 
                                    style="background:linear-gradient(135deg, var(--accent-cyan), var(--accent-purple));color:white;border:none;padding:5px 10px;border-radius:5px;cursor:pointer;font-size:12px;">
                                    <i class="fa-solid fa-share-nodes"></i> Share
                                </button>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </main>

</div>

<!-- Toast Notification -->
<div class="toast" id="toast">
    <i class="fa-solid fa-check-circle"></i> <span id="toast-msg">Link copied!</span>
</div>

<style>
    .toast {
        position: fixed;
        bottom: 30px;
        left: 50%;
        transform: translateX(-50%) translateY(100px);
        background: var(--text-primary);
        color: var(--bg-primary);
        padding: 12px 24px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 8px;
        z-index: 9999;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2);
    }
    .toast.show {
        transform: translateX(-50%) translateY(0);
    }
</style>

<script>
    function openNoteFromAll(element) {
        const title = element.getAttribute('data-title');
        window.location.href = "/dashboard?title=" + encodeURIComponent(title);
    }

    async function shareNote(noteId) {
        try {
            const res = await fetch('/api/share-link/' + noteId);
            const data = await res.json();
            if (data.shareUrl) {
                await navigator.clipboard.writeText(data.shareUrl);
                showToast('Share link copied to clipboard!');
            } else {
                showToast('Could not generate share link');
            }
        } catch (err) {
            console.error(err);
            showToast('Error generating share link');
        }
    }

    function showToast(msg) {
        const toast = document.getElementById('toast');
        document.getElementById('toast-msg').textContent = msg;
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 2500);
    }
</script>
<script src="/theme.js"></script>
</body>
</html>
