<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Notes | MindVault</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

<div class="dashboard-layout">
    
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <h2><i class="fa-solid fa-brain gradient-text"></i> MindVault</h2>
        </div>
        
        <nav class="sidebar-nav">
            <a href="/dashboard" class="nav-item">
                <i class="fa-solid fa-pen-nib"></i> Editor
            </a>
            <a href="/all-notes" class="nav-item active">
                <i class="fa-solid fa-book-open"></i> All Notes
            </a>
            <a href="/projects" class="nav-item">
                <i class="fa-solid fa-folder-tree"></i> Projects
            </a>
            <a href="/analytics" class="nav-item">
                <i class="fa-solid fa-chart-pie"></i> Analytics
            </a>
        </nav>
        
        <div class="sidebar-footer">
            <div class="user-profile">
                <div class="avatar"><%= user.charAt(0).toUpperCase() %></div>
                <div>
                    <div style="font-weight: 600; font-size: 14px;"><%= user %></div>
                    <div style="font-size: 12px; color: var(--text-secondary);">Pro Plan</div>
                </div>
            </div>
            <a href="/logout" title="Logout" style="color: var(--text-secondary);"><i class="fa-solid fa-arrow-right-from-bracket"></i></a>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="main-content">
        <div class="editor-header">
            <div style="color: var(--text-secondary); font-size: 14px;">
                <i class="fa-solid fa-book-open"></i> All Notes
            </div>
        </div>

        <div class="editor-body">
            <div class="notes-container" style="margin-top: 0;">
                <div class="notes-header">
                    <h3 style="font-size: 24px;">Your Knowledge Vault</h3>
                </div>
                
                <div class="notes-grid">
                    <% if(notes.length === 0){ %>
                        <div class="empty-state" style="grid-column: 1 / -1;">
                            <i class="fa-regular fa-folder-open"></i>
                            <p>No notes found. Create your first note in the Editor!</p>
                            <br>
                            <a href="/dashboard" class="btn btn-primary">Go to Editor</a>
                        </div>
                    <% } %>

                    <% notes.forEach(note => { %>
                        <div class="note-card" data-title="<%= note.title %>" data-content="<%= note.content %>" onclick="openNoteFromAll(this)">
                            <h3><%= note.title %></h3>
                            <p><%= note.content %></p>
                            <div style="margin-top: 15px; font-size: 12px; color: var(--text-secondary); display: flex; justify-content: space-between;">
                                <span><i class="fa-regular fa-clock"></i> Saved</span>
                                <span style="color: var(--accent-purple);"><i class="fa-solid fa-wand-magic-sparkles"></i> AI Indexed</span>
                            </div>
                                <form action="/delete-note" method="POST" style="margin-top:10px;">
                                    <input type="hidden" name="title" value="<%= note.title %>">
                                    <button type="submit"
                                        style="background:red;color:white;border:none;padding:5px 10px;border-radius:5px;cursor:pointer;">
                                        Delete
                                    </button>
                                </form>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </main>

</div>

<script>
    function openNoteFromAll(element) {
        const title = element.getAttribute('data-title');
        window.location.href = "/dashboard?title=" + encodeURIComponent(title);
    }
</script>
<script src="/theme.js"></script>
</body>
</html>
