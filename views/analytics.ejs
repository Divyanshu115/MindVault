<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analytics | MindVault</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

<div class="dashboard-layout">
    
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <h2><i class="fa-solid fa-brain gradient-text"></i> MindVault</h2>
        </div>
        
        <nav class="sidebar-nav">
            <a href="/dashboard" class="nav-item">
                <i class="fa-solid fa-pen-nib"></i> Editor
            </a>
            <a href="/all-notes" class="nav-item">
                <i class="fa-solid fa-book-open"></i> All Notes
            </a>
            <a href="/syllabus" class="nav-item">
                <i class="fa-solid fa-graduation-cap"></i> Syllabus Notes
            </a>
            <a href="/deadlines" class="nav-item">
                <i class="fa-solid fa-clock"></i> Deadlines
            </a>
            <a href="/analytics" class="nav-item active">
                <i class="fa-solid fa-chart-pie"></i> Analytics
            </a>
        </nav>
        
        <div class="sidebar-footer">
            <div class="user-profile">
                <div class="avatar"><%= user.charAt(0).toUpperCase() %></div>
                <div>
                    <div style="font-weight: 600; font-size: 14px;"><%= user %></div>
                    <div style="font-size: 12px; color: var(--text-secondary);">Pro Plan</div>
                </div>
            </div>
            <a href="/logout" title="Logout" style="color: var(--text-secondary);"><i class="fa-solid fa-arrow-right-from-bracket"></i></a>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="main-content">
        <div class="editor-header">
            <div style="color: var(--text-secondary); font-size: 14px;">
                <i class="fa-solid fa-chart-pie"></i> Analytics
            </div>
        </div>

        <div class="editor-body">
            <h3 style="font-size: 24px; margin-bottom: 30px;">Knowledge Base Stats</h3>
            
            <div style="display: flex; gap: 20px;">
                <div class="glass-panel" style="padding: 30px; flex: 1; text-align: center;">
                    <i class="fa-solid fa-file-lines" style="font-size: 32px; color: var(--accent-purple); margin-bottom: 15px;"></i>
                    <h4 style="color: var(--text-secondary); font-weight: normal;">Total Notes</h4>
                    <p style="font-size: 36px; font-weight: bold; font-family: var(--font-display);"><%= noteCount %></p>
                </div>

                <div class="glass-panel" style="padding: 30px; flex: 1; text-align: center;">
                    <i class="fa-solid fa-brain" style="font-size: 32px; color: var(--accent-cyan); margin-bottom: 15px;"></i>
                    <h4 style="color: var(--text-secondary); font-weight: normal;">AI Insights Generated</h4>
                    <p style="font-size: 36px; font-weight: bold; font-family: var(--font-display);"><%= aiCount %></p>
                </div>
            </div>

            <div class="empty-state" style="margin-top: 60px;">
                <p>More detailed analytics on your reading and writing habits will appear here soon.</p>
            </div>
        </div>
    </main>

</div>

<script src="/theme.js"></script>
</body>
</html>
