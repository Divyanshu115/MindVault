<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | MindVault</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>

    <div class="dashboard-layout">

        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2><i class="fa-solid fa-brain gradient-text"></i> MindVault</h2>
            </div>

            <nav class="sidebar-nav">
                <a href="/dashboard" class="nav-item active">
                    <i class="fa-solid fa-pen-nib"></i> Editor
                </a>
                <a href="/all-notes" class="nav-item">
                    <i class="fa-solid fa-book-open"></i> All Notes
                </a>
                <a href="/syllabus" class="nav-item">
                    <i class="fa-solid fa-graduation-cap"></i> Syllabus Notes
                </a>
                <a href="/deadlines" class="nav-item">
                    <i class="fa-solid fa-clock"></i> Deadlines
                </a>
                <a href="/analytics" class="nav-item">
                    <i class="fa-solid fa-chart-pie"></i> Analytics
                </a>
            </nav>

            <div class="sidebar-footer">
                <div class="user-profile">
                    <div class="avatar">
                        <%= user.charAt(0).toUpperCase() %>
                    </div>
                    <div>
                        <div style="font-weight: 600; font-size: 14px;">
                            <%= user %>
                        </div>
                        <div style="font-size: 12px; color: var(--text-secondary);">Pro Plan</div>
                    </div>
                </div>
                <a href="/logout" title="Logout" style="color: var(--text-secondary);"><i
                        class="fa-solid fa-arrow-right-from-bracket"></i></a>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="main-content">

            <div class="editor-header">
                <div style="color: var(--text-secondary); font-size: 14px;">
                    <i class="fa-regular fa-folder"></i> Personal / New Note
                </div>
                <div class="editor-toolbar">
                    <button class="btn btn-outline" style="padding: 6px 12px; font-size: 13px;" id="btn-share-note" onclick="shareCurrentNote()"><i
                            class="fa-solid fa-share-nodes"></i> Share</button>
                    <button class="btn btn-primary" style="padding: 6px 12px; font-size: 13px;" form="note-form"><i
                            class="fa-solid fa-check"></i> Save Note</button>
                </div>
            </div>

            <div class="editor-body">

                <form action="/add-note" method="POST" id="note-form" class="note-composer">

                    <input type="text" name="title" class="title-input" placeholder="Untitled Note..." required
                        autocomplete="off">

                    <div class="ai-toolbar glass-panel">
                        <button type="button" class="btn btn-ai" style="padding: 6px 12px; font-size: 13px;"
                            id="btn-ask-ai"><i class="fa-solid fa-wand-magic-sparkles"></i> Ask AI</button>
                        <button type="button" class="btn btn-outline"
                            style="padding: 6px 12px; font-size: 13px; border-color: rgba(255,255,255,0.1);"
                            id="btn-summarize"><i class="fa-solid fa-list"></i> Summarize</button>
                        <button type="button" class="btn btn-outline"
                            style="padding: 6px 12px; font-size: 13px; border-color: rgba(255,255,255,0.1);"
                            id="btn-translate"><i class="fa-solid fa-language"></i> Translate</button>
                        <button type="button" class="btn btn-ai" id="btn-quiz"><i
                                class="fa-solid fa-question-circle"></i> Generate Quiz</button>
                    </div>

                    <div id="ai-result-container"
                        style="display: none; margin-top: 15px; margin-bottom: 15px; padding: 15px; border-radius: 8px; background: rgba(139, 92, 246, 0.1); border: 1px solid rgba(139, 92, 246, 0.3);">
                        <div
                            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                            <span style="color: var(--accent-purple); font-weight: 600;"><i
                                    class="fa-solid fa-robot"></i> AI Response</span>
                            <button type="button" id="close-ai-result"
                                style="background: none; border: none; color: var(--text-secondary); cursor: pointer; font-size: 16px;"><i
                                    class="fa-solid fa-times"></i></button>
                        </div>
                        <div id="ai-result-content" style="font-size: 14px; line-height: 1.6;"></div>
                    </div>


                    <div id="note-view" style="
                  padding:20px;
                  border-radius:12px;
                  background: var(--bg-panel);
                  border:1px solid var(--border-light);
                  line-height:1.8;
                  margin-top:10px;
                  min-height:200px;
                "></div>

                    <textarea name="content" class="content-input" style="display:none;" placeholder="Start typing..."
                        required></textarea>

                    <button type="button" id="editBtn" class="btn btn-outline" style="margin-top:10px;">
                        ✏️ Edit
                    </button>

                </form>

                <form action="/upload-pdf" method="POST" enctype="multipart/form-data" class="note-composer" style="margin-bottom: 20px; padding: 15px; border-radius: 8px; background: rgba(139, 92, 246, 0.05); border: 1px dashed rgba(139, 92, 246, 0.3);">
                    <div style="margin-bottom: 10px; font-weight: 600; color: var(--accent-purple);"><i class="fa-solid fa-file-pdf"></i> Extract Note from PDF</div>
                    <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
                        <input type="text" name="title" class="title-input" placeholder="PDF Note Title (optional)" autocomplete="off" style="flex: 1; min-width: 200px; margin-bottom: 0;">
                        <input type="file" name="pdf" accept="application/pdf" required style="flex: 1; min-width: 200px;">
                        <button type="submit" class="btn btn-primary" style="padding: 10px 20px;"><i class="fa-solid fa-upload"></i> Upload & Extract</button>
                    </div>
                </form>

                <div class="notes-container">
                    <div class="notes-header">
                        <h3 style="font-size: 20px;">Recent Notes (<%= notes.length %>)</h3>
                    </div>

                    <div class="notes-grid">
                        <% if(notes.length===0){ %>
                            <div class="empty-state" style="grid-column: 1 / -1;">
                                <i class="fa-regular fa-folder-open"></i>
                                <p>No notes found. Create your first note above!</p>
                            </div>
                            <% } %>

                                <% notes.forEach(note=> { %>
                                    <div class="note-card" data-title="<%= note.title %>"
                                        data-content="<%= note.content %>" data-id="<%= note._id %>" onclick="openNote(this)">
                                        <h3>
                                            <%= note.title %>
                                        </h3>
                                        <p>
                                            <%= note.content %>
                                        </p>
                                        <div
                                            style="margin-top: 15px; font-size: 12px; color: var(--text-secondary); display: flex; justify-content: space-between;">
                                            <span><i class="fa-regular fa-clock"></i> Just now</span>
                                            <span style="color: var(--accent-purple);"><i
                                                    class="fa-solid fa-wand-magic-sparkles"></i> AI Synced</span>
                                        </div>
                                        <div style="margin-top:10px; display:flex; gap:8px; align-items:center;">
                                            <form action="/delete-note" method="POST" style="margin:0;">
                                                <input type="hidden" name="title" value="<%= note.title %>">
                                                <button type="submit"
                                                    style="background:red;color:white;border:none;padding:5px 10px;border-radius:5px;cursor:pointer;">
                                                    Delete
                                                </button>
                                            </form>
                                            <button type="button" onclick="event.stopPropagation(); shareNote('<%= note._id %>')" 
                                                style="background:linear-gradient(135deg, var(--accent-cyan), var(--accent-purple));color:white;border:none;padding:5px 10px;border-radius:5px;cursor:pointer;font-size:12px;">
                                                <i class="fa-solid fa-share-nodes"></i> Share
                                            </button>
                                        </div>
                                    </div>
                                    <% }) %>
                    </div>
                </div>

            </div>
        </main>

    </div>

    <script>
        const btnAskAi = document.getElementById('btn-ask-ai');
        const btnSummarize = document.getElementById('btn-summarize');
        const btnTranslate = document.getElementById('btn-translate');
        const contentInput = document.querySelector('.content-input');
        const aiResultContainer = document.getElementById('ai-result-container');
        const aiResultContent = document.getElementById('ai-result-content');
        const closeAiResult = document.getElementById('close-ai-result');
        const btnQuiz = document.getElementById('btn-quiz');

        closeAiResult.addEventListener('click', () => {
            aiResultContainer.style.display = 'none';
        });

        async function callAI(data) {
            aiResultContainer.style.display = 'block';
            aiResultContent.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Processing...';

            try {
                const response = await fetch('/api/ai', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await response.json();

                if (response.ok) {
                    // simple formatting
                    let formattedResult = result.result;
                    // Parse markdown bold
                    formattedResult = formattedResult.replace(/\*\*(.*?)\*\*/g, '<b>$1</b>');
                    // Parse line breaks
                    formattedResult = formattedResult.replace(/\n/g, '<br>');
                    // Remove any leftover rogue *
                    formattedResult = formattedResult.replace(/\*/g, '');

                    aiResultContent.innerHTML = formattedResult;
                } else {
                    aiResultContent.innerHTML = `<span style="color: #ff4d4d;">Try again</span>`;
                }
            } catch (error) {
                aiResultContent.innerHTML = `<span style="color: #ff4d4d;">Try again</span>`;
            }
        }

        btnSummarize.addEventListener('click', () => {
            const content = contentInput.value.trim() || document.getElementById("note-view").innerText.trim();
            if (!content) return alert("Please write some content first!");
            callAI({ action: "summarize", content: content });
        });

        btnTranslate.addEventListener('click', () => {
            const content = contentInput.value.trim() || document.getElementById("note-view").innerText.trim();
            if (!content) return alert("Please write some content first!");
            const language = prompt("What language do you want to translate to? (e.g. Spanish, French, Hindi)");
            if (language) {
                callAI({ action: "translate", content: content, language: language });
            }
        });

        btnAskAi.addEventListener('click', () => {
            const content = contentInput.value.trim() || document.getElementById("note-view").innerText.trim();
            if (!content) return alert("Please write some content first!");
            const question = prompt("Ask a question about your note:");
            if (question) {
                callAI({ action: "ask", content: content, question: question });
            }
        });
        btnQuiz.addEventListener('click', () => {
            const content = contentInput.value.trim() || document.getElementById("note-view").innerText.trim();
            if (!content) return alert("Please write some content first!");

            callAI({ action: "quiz", content: content });
        });

        // Track currently open note ID for the header Share button
        let currentNoteId = null;

        function openNote(element) {
            const title = element.getAttribute('data-title');
            const content = element.getAttribute('data-content');
            currentNoteId = element.getAttribute('data-id');

            document.querySelector('.title-input').value = title;

            const view = document.getElementById("note-view");
            const textarea = document.querySelector('.content-input');

            view.innerHTML = content.replace(/\n/g, "<br>");
            textarea.value = content;

            view.style.display = "block";
            textarea.style.display = "none";

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // ── Share Functions ──
        async function shareNote(noteId) {
            try {
                const res = await fetch('/api/share-link/' + noteId);
                const data = await res.json();
                if (data.shareUrl) {
                    await navigator.clipboard.writeText(data.shareUrl);
                    showToast('Share link copied to clipboard!');
                } else {
                    showToast('Could not generate share link');
                }
            } catch (err) {
                console.error(err);
                showToast('Error generating share link');
            }
        }

        function shareCurrentNote() {
            if (!currentNoteId) {
                return alert('Please open a saved note first to share it.');
            }
            shareNote(currentNoteId);
        }

        function showToast(msg) {
            const toast = document.getElementById('toast');
            document.getElementById('toast-msg').textContent = msg;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 2500);
        }

window.onload = function () {
    const urlParams = new URLSearchParams(window.location.search);
    const title = urlParams.get('title');
    
    if (title) {
        const noteCards = document.querySelectorAll('.note-card');
        let targetNote = null;
        for (let i = 0; i < noteCards.length; i++) {
            if (noteCards[i].getAttribute('data-title') === title) {
                targetNote = noteCards[i];
                break;
            }
        }
        
        if (targetNote) {
            openNote(targetNote);
        } else {
            document.querySelector('.title-input').value = title;
        }
        
        // Clear query params from URL
        window.history.replaceState({}, document.title, "/dashboard");
    }
};
        document.getElementById("editBtn").addEventListener("click", function () {
            document.getElementById("note-view").style.display = "none";
            document.querySelector('.content-input').style.display = "block";
        });

    </script>

    <!-- Toast Notification -->
    <div class="toast" id="toast">
        <i class="fa-solid fa-check-circle"></i> <span id="toast-msg">Link copied!</span>
    </div>

    <style>
        .toast {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%) translateY(100px);
            background: var(--text-primary);
            color: var(--bg-primary);
            padding: 12px 24px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 8px;
            z-index: 9999;
            transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2);
        }
        .toast.show {
            transform: translateX(-50%) translateY(0);
        }
    </style>

    <script src="/theme.js"></script>
</body>

</html>