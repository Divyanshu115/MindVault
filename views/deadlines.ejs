<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Deadlines & Timers | MindVault</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .timer-display {
            font-size: 1.5rem;
            font-family: var(--font-display);
            font-weight: bold;
            color: var(--accent-purple);
            margin: 10px 0;
            display: flex;
            gap: 10px;
        }

        .timer-box {
            background: rgba(139, 92, 246, 0.1);
            padding: 10px;
            border-radius: 8px;
            text-align: center;
            min-width: 60px;
            border: 1px solid rgba(139, 92, 246, 0.2);
        }

        .timer-box span {
            display: block;
            font-size: 0.75rem;
            color: var(--text-secondary);
            font-weight: normal;
            text-transform: uppercase;
            margin-top: 5px;
        }

        .deadline-card {
            background: var(--bg-panel);
            border: 1px solid var(--border-light);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .deadline-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
            border-color: var(--accent-purple);
        }

        .type-badge {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 999px;
            /* pill shape */
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .type-badge:hover {
            transform: scale(1.05);
            transition: 0.2s ease;
        }

        .type-Exam {
            background: linear-gradient(135deg, #ef4444, #dc2626);
            color: #fff;
            box-shadow: 0 4px 10px rgba(239, 68, 68, 0.4);
        }

        .type-Evaluation {
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            color: #fff;
            box-shadow: 0 4px 10px rgba(59, 130, 246, 0.4);
        }

        .type-Assignment {
            background: linear-gradient(135deg, #10b981, #059669);
            color: #fff;
            box-shadow: 0 4px 10px rgba(16, 185, 129, 0.4);
        }
    </style>
</head>

<body>

    <div class="dashboard-layout">

        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2><i class="fa-solid fa-brain gradient-text"></i> MindVault</h2>
            </div>

            <nav class="sidebar-nav">
                <a href="/dashboard" class="nav-item">
                    <i class="fa-solid fa-pen-nib"></i> Editor
                </a>
                <a href="/all-notes" class="nav-item">
                    <i class="fa-solid fa-book-open"></i> All Notes
                </a>
                <a href="/syllabus" class="nav-item">
                    <i class="fa-solid fa-graduation-cap"></i> Syllabus Notes
                </a>
                <a href="/deadlines" class="nav-item active">
                    <i class="fa-solid fa-clock"></i> Deadlines
                </a>
                <a href="/analytics" class="nav-item">
                    <i class="fa-solid fa-chart-pie"></i> Analytics
                </a>
            </nav>

            <div class="sidebar-footer">
                <div class="user-profile">
                    <div class="avatar">
                        <%= user.charAt(0).toUpperCase() %>
                    </div>
                    <div>
                        <div style="font-weight: 600; font-size: 14px;">
                            <%= user %>
                        </div>
                        <div style="font-size: 12px; color: var(--text-secondary);">Pro Plan</div>
                    </div>
                </div>
                <a href="/logout" title="Logout" style="color: var(--text-secondary);"><i
                        class="fa-solid fa-arrow-right-from-bracket"></i></a>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="main-content">
            <div class="editor-header">
                <div style="color: var(--text-secondary); font-size: 14px;">
                    <i class="fa-solid fa-clock"></i> Deadlines & Timers
                </div>
            </div>

            <div class="editor-body">

                <form action="/add-deadline" method="POST" class="note-composer" style="margin-bottom: 30px;"
                    id="deadline-form">
                    <div style="margin-bottom: 15px; font-weight: 600; color: var(--accent-purple);">
                        <i class="fa-solid fa-plus"></i> Add New Deadline / Exam Timer
                    </div>

                    <div style="display: flex; gap: 15px; flex-wrap: wrap;">
                        <input type="text" name="title" class="title-input" placeholder="e.g. Final Semester Exam"
                            required autocomplete="off" style="flex: 2; min-width: 200px; margin-bottom: 0;">

                        <select name="type" required
                            style="flex: 1; min-width: 150px; background: var(--bg-dark); color: var(--text-primary); border: 1px solid var(--border-light); padding: 12px; border-radius: 8px;">
                            <option value="Exam">Exam</option>
                            <option value="Evaluation">Evaluation</option>
                            <option value="Assignment">Assignment</option>
                            <option value="Other">Other</option>
                        </select>

                        <input type="datetime-local" name="dueDateLocal" id="dueDateLocal" required
                            style="flex: 1; min-width: 200px; background: var(--bg-dark); color: var(--text-primary); border: 1px solid var(--border-light); padding: 12px; border-radius: 8px; color-scheme: dark;">

                        <!-- Hidden field to send the proper ISO string with timezone -->
                        <input type="hidden" name="dueDate" id="dueDateISO">

                        <button type="submit" class="btn btn-primary" style="padding: 10px 20px;">
                            <i class="fa-solid fa-stopwatch"></i> Start Timer
                        </button>
                    </div>
                </form>

                <div class="notes-container">
                    <div class="notes-header">
                        <h3 style="font-size: 20px;">Active Timers (<%= deadlines.length %>)</h3>
                    </div>

                    <div
                        style="display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 20px;">
                        <% if(deadlines.length===0){ %>
                            <div class="empty-state" style="grid-column: 1 / -1;">
                                <i class="fa-regular fa-clock"></i>
                                <p>No active deadlines. Create a timer above!</p>
                            </div>
                            <% } %>

                                <% deadlines.forEach(deadline=> { %>
                                    <div class="deadline-card">
                                        <div
                                            style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px;">
                                            <div>
                                                <span class="type-badge type-<%= deadline.type %>">
                                                    <%= deadline.type %>
                                                </span>
                                                <h3 style="margin: 10px 0 5px 0; font-size: 1.2rem;">
                                                    <%= deadline.title %>
                                                </h3>
                                                <div style="font-size: 0.85rem; color: var(--text-secondary);"
                                                    class="due-date-display"
                                                    data-due-raw="<%= deadline.dueDate.toISOString() %>">
                                                    <i class="fa-regular fa-calendar"></i>
                                                    <span>Loading...</span>
                                                </div>
                                            </div>
                                            <form action="/delete-deadline" method="POST">
                                                <input type="hidden" name="id" value="<%= deadline._id %>">
                                                <button type="submit"
                                                    style="background: none; border: none; color: #ef4444; cursor: pointer; font-size: 1.1rem; padding: 5px;"
                                                    title="Delete Timer">
                                                    <i class="fa-solid fa-trash-can"></i>
                                                </button>
                                            </form>
                                        </div>

                                        <div class="timer-display" data-due="<%= deadline.dueDate.toISOString() %>">
                                            <div class="timer-box">
                                                <div class="days">--</div><span>Days</span>
                                            </div>
                                            <div class="timer-box">
                                                <div class="hours">--</div><span>Hrs</span>
                                            </div>
                                            <div class="timer-box">
                                                <div class="mins">--</div><span>Min</span>
                                            </div>
                                            <div class="timer-box">
                                                <div class="secs">--</div><span>Sec</span>
                                            </div>
                                        </div>
                                    </div>
                                    <% }) %>
                    </div>
                </div>

            </div>
        </main>

    </div>

    <script>
        // Convert the local datetime-local value to a proper ISO string before submitting
        const deadlineForm = document.getElementById('deadline-form');
        if (deadlineForm) {
            deadlineForm.addEventListener('submit', function (e) {
                const localInput = document.getElementById('dueDateLocal');
                const isoInput = document.getElementById('dueDateISO');
                if (localInput.value) {
                    // new Date() with datetime-local value interprets it as LOCAL time in the browser
                    const localDate = new Date(localInput.value);
                    isoInput.value = localDate.toISOString();
                }
            });
        }

        // Display due dates in the user's local timezone (client-side)
        document.querySelectorAll('.due-date-display').forEach(el => {
            const isoStr = el.getAttribute('data-due-raw');
            if (isoStr) {
                const d = new Date(isoStr);
                const spanEl = el.querySelector('span');
                if (spanEl) {
                    spanEl.textContent = d.toLocaleString();
                }
            }
        });

        function updateTimers() {
            const timers = document.querySelectorAll('.timer-display');

            timers.forEach(timer => {
                const dueStr = timer.getAttribute('data-due');
                if (!dueStr) return;

                const dueDate = new Date(dueStr).getTime();
                const now = new Date().getTime();
                const distance = dueDate - now;

                if (distance < 0) {
                    if (!timer.classList.contains('expired')) {
                        timer.classList.add('expired');
                        timer.innerHTML = '<div style="color: #ef4444; font-size: 1.2rem; margin-top: 10px;"><i class="fa-solid fa-circle-exclamation"></i> Deadline Passed!</div>';
                    }
                    return;
                }

                const days = Math.floor(distance / (1000 * 60 * 60 * 24));
                const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                const dEl = timer.querySelector('.days');
                const hEl = timer.querySelector('.hours');
                const mEl = timer.querySelector('.mins');
                const sEl = timer.querySelector('.secs');

                if (dEl) dEl.innerText = days.toString().padStart(2, '0');
                if (hEl) hEl.innerText = hours.toString().padStart(2, '0');
                if (mEl) mEl.innerText = minutes.toString().padStart(2, '0');
                if (sEl) sEl.innerText = seconds.toString().padStart(2, '0');
            });
        }

        // Update timers immediately and then every second
        updateTimers();
        setInterval(updateTimers, 1000);
    </script>
    <script src="/theme.js"></script>
</body>

</html>